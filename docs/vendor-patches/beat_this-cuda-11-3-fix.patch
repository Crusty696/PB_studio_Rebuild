From: David Lochmann <david@local>
Date: Sun, 12 Apr 2026 22:21:16 +0200
Subject: [PATCH 1/2] fix: scaled_dot_product_attention Fallback fuer torch
 1.12

---
 beat_this/model/roformer.py | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/beat_this/model/roformer.py b/beat_this/model/roformer.py
index d1cdd3c..885a431 100644
--- a/beat_this/model/roformer.py
+++ b/beat_this/model/roformer.py
@@ -9,6 +9,20 @@ from einops import rearrange
 from torch import nn
 from torch.nn import Module, ModuleList
 
+# Compat: F.scaled_dot_product_attention existiert erst ab PyTorch 2.0
+# Fuer torch 1.12: manuelle Implementierung (mathematisch identisch)
+if not hasattr(F, 'scaled_dot_product_attention'):
+    def _scaled_dot_product_attention(query, key, value, attn_mask=None, dropout_p=0.0, is_causal=False):
+        scale = query.shape[-1] ** -0.5
+        attn_weight = torch.matmul(query, key.transpose(-2, -1)) * scale
+        if attn_mask is not None:
+            attn_weight = attn_weight + attn_mask
+        attn_weight = torch.softmax(attn_weight, dim=-1)
+        if dropout_p > 0.0:
+            attn_weight = torch.dropout(attn_weight, dropout_p, train=True)
+        return torch.matmul(attn_weight, value)
+    F.scaled_dot_product_attention = _scaled_dot_product_attention
+
 # helper functions
 
 
